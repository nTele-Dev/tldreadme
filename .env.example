# Local-first defaults
OLLAMA_URL=http://localhost:11434
QDRANT_URL=http://localhost:6333
FALKORDB_URL=redis://localhost:6379
TLDREADME_EMBED_MODEL=ollama/nomic-embed-text
TLDREADME_CHAT_MODEL=ollama/qwen2.5-coder:3b-instruct

# Optional LiteLLM proxy
# Leave blank for direct local Ollama. Set this when using docker-compose.llm.yml
# or another LiteLLM endpoint.
LITELLM_URL=

# Optional cloud provider credentials for LiteLLM
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
