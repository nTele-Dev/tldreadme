# TLDREADME Configuration

# LLM Backends (all optional — defaults to local Ollama)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=

# LiteLLM endpoint (if running via docker compose, leave default)
LITELLM_URL=http://localhost:4000

# Qdrant
QDRANT_URL=http://localhost:6333

# FalkorDB
FALKORDB_URL=redis://localhost:6379

# Watch directories (comma-separated, or pass via CLI)
TLDREADME_WATCH_DIRS=/Users/claude/redfire-switch,/Volumes/Expansion/Qubed
